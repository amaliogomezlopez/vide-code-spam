# --- Server ---
HOST=127.0.0.1
PORT=8000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
# Optional for non-Electron clients. Required when binding outside loopback.
VIBE_SPAM_API_TOKEN=
TRUSTED_PROXY_MODE=false

# --- Audio ---
SAMPLE_RATE=16000
AUDIO_FORMAT=webm
MAX_AUDIO_BYTES=20971520

# --- STT Provider: faster-whisper | openwhispr ---
STT_PROVIDER=faster-whisper
WHISPER_MODEL_SIZE=large-v3-turbo
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=1
WHISPER_LANGUAGE=es

# OpenWhispr (optional)
OPENWHISPR_URL=http://localhost:8001/transcribe

# --- LLM Cleaner Provider: ollama | groq | none ---
LLM_CLEANER_PROVIDER=none
LLM_CLEANER_MODEL=llama3.1:8b
LLM_CLEANER_TEMPERATURE=0.0

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Groq (optional, cheap & fast)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Default agents (optional overrides) ---
# AGENT_OVERRIDES={"claude":{"name":"Claude","command":"claude"},"codex":{"name":"Codex","command":"codex"}}
