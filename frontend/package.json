{
  "name": "vibe-spam",
  "description": "Desktop orchestrator for multiple coding CLIs with local voice dictation.",
  "author": "Amalio Gomez Lopez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amaliogomezlopez/vide-code-spam.git"
  },
  "homepage": "https://github.com/amaliogomezlopez/vide-code-spam",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "electron:compile": "tsc -p tsconfig.electron.json && node -e \"for (const f of ['preload.cjs','overlay-preload.cjs']) require('fs').copyFileSync('electron/'+f,'dist-electron/'+f)\"",
    "electron:dev": "npm run build && npm run electron:compile && electron .",
    "electron:build": "npm run build && npm run electron:compile && electron-builder",
    "electron:pack": "electron-builder",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.vibespam.app",
    "productName": "Vibe Spam",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend-dist",
        "to": "backend"
      },
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Vibe Spam necesita el micrófono para convertir tu voz en texto.",
        "NSAppleEventsUsageDescription": "Vibe Spam usa Accesibilidad para pegar el dictado en la aplicación que tengas enfocada."
      }
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "assets/vibe-spam.ico",
      "extraResources": [
        {
          "from": "inserter-dist",
          "to": "inserter"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vibe Spam"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
